}

// ============================================================
// 22. AltCandidate
// ============================================================

model AltCandidate {
  id                String                     @id @default(cuid())
  shopId            String                     @map("shop_id")
  altTargetId       String                     @unique @map("alt_target_id")
  status            AltCandidateStatus         @default(MISSING)
  missingReason     AltCandidateMissingReason? @map("missing_reason")
  riskFlags         Json                       @default("[]") @map("risk_flags")
  firstSeenAt       DateTime                   @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime                   @default(now()) @map("last_seen_at")
  lastSeenScanJobId String                     @map("last_seen_scan_job_id")
  writtenAt         DateTime?                  @map("written_at")
  errorCode         String?                    @map("error_code")
  errorMessage      String?                    @map("error_message")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop             Shop                       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  altTarget        AltTarget                  @relation(fields: [altTargetId], references: [id], onDelete: Cascade)
  lastSeenScanJob  ScanJob                    @relation("LastSeenScanJobAltCandidates", fields: [lastSeenScanJobId], references: [id], onDelete: Cascade)
  groupProjections CandidateGroupProjection[]
  draft            AltDraft?
  jobItems         JobItem[]
  auditLogs        AuditLog[]

  // ---------- Indexes ----------
  @@index([shopId])
  @@index([altTargetId])
  @@index([lastSeenScanJobId])
  @@index([shopId, status, lastSeenAt])
  @@map("alt_candidate")
}

// ============================================================
