// ============================================================
// 25. AuditLog
// ============================================================

model AuditLog {
  id             String   @id @default(cuid())
  shopId         String   @map("shop_id")
  jobBatchId     String?  @map("job_batch_id")
  jobItemId      String?  @map("job_item_id")
  altTargetId    String   @map("alt_target_id")
  altCandidateId String   @map("alt_candidate_id")
  altDraftId     String?  @map("alt_draft_id")
  idempotencyKey String   @unique @map("idempotency_key")
  altPlane       AltPlane @map("alt_plane")
  writeTargetId  String   @map("write_target_id")
  oldAltText     String?  @map("old_alt_text")
  newAltText     String   @map("new_alt_text")
  writtenAt      DateTime @default(now()) @map("written_at")
  modelUsed      String   @map("model_used")
  createdAt      DateTime @default(now()) @map("created_at")

  // ---------- Relations ----------
  shop         Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobBatch     JobBatch?    @relation(fields: [jobBatchId], references: [id], onDelete: SetNull)
  jobItem      JobItem?     @relation(fields: [jobItemId], references: [id], onDelete: SetNull)
  altTarget    AltTarget    @relation(fields: [altTargetId], references: [id], onDelete: Cascade)
  altCandidate AltCandidate @relation(fields: [altCandidateId], references: [id], onDelete: Cascade)
  altDraft     AltDraft?    @relation(fields: [altDraftId], references: [id], onDelete: SetNull)

  // ---------- Indexes ----------
  @@index([shopId])
  @@index([jobBatchId])
  @@index([jobItemId])
  @@index([altTargetId])
  @@index([altCandidateId])
  @@index([altDraftId])
  @@unique([shopId, writeTargetId, altCandidateId])
  @@index([shopId, writtenAt])
  @@index([shopId, altPlane, writtenAt])
  @@index([shopId, writeTargetId, writtenAt])
  @@map("audit_log")
}

// ============================================================
