// ============================================================
// AltText Magic - Phase 1 Prisma Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// 0. Enums
// ============================================================

enum ScanJobStatus {
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

enum ScanJobPublishStatus {
  PENDING
  PUBLISHED
  NOT_PUBLISHED
}

enum ScanResourceType {
  PRODUCT_MEDIA
  FILES
  COLLECTION_IMAGE
  ARTICLE_IMAGE
}

enum ScanTaskStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum ScanTaskAttemptStatus {
  PENDING
  RUNNING
  READY_TO_PARSE
  PARSING
  SUCCESS
  FAILED
}

enum JobBatchType {
  SCAN
  GENERATE
  WRITEBACK
}

enum JobBatchStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

enum JobItemStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED_ALREADY_FILLED
}

enum ResourceImageFingerprintResourceType {
  PRODUCT
  COLLECTION
}

enum AltPlane {
  FILE_ALT
  COLLECTION_IMAGE_ALT
  ARTICLE_IMAGE_ALT
}

enum ImageUsageType {
  PRODUCT
  FILE
}

enum PresentStatus {
  PRESENT
  NOT_FOUND
}

enum AltCandidateStatus {
  MISSING
  GENERATION_FAILED_RETRYABLE
  GENERATED
  WRITEBACK_FAILED_RETRYABLE
  WRITTEN
  RESOLVED
  NOT_FOUND
  DECORATIVE_SKIPPED
  SKIPPED_ALREADY_FILLED
}

enum AltCandidateMissingReason {
  EMPTY
  WHITESPACE
}

enum CandidateGroupType {
  PRODUCT_MEDIA
  FILES
  COLLECTION
  ARTICLE
}

enum CandidateGroupPrimaryUsageType {
  PRODUCT
  FILE
  SELF
}

enum AltDraftContextMode {
  RESOURCE_SPECIFIC
  FILE_NEUTRAL
  SHARED_NEUTRAL
}

enum WebhookEventStatus {
  PENDING
  COALESCED
  PROCESSING
  PROCESSED
  SKIPPED_PLAN
  SKIPPED_SCOPE
  SKIPPED_NO_IMAGE_CHANGE
  FAILED
}

enum BillingPlanCode {
  FREE
  STARTER
  GROWTH
  PRO
  MAX
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum BillingSubscriptionStatus {
  PENDING
  ACTIVE
  CANCEL_SCHEDULED
  CANCELED
  EXPIRED
  FAILED
}

enum OveragePackPurchaseStatus {
  PENDING
  PURCHASED
  FAILED
  REFUNDED
  VOIDED
}

enum CreditBucketType {
  FREE_MONTHLY_INCLUDED
  MONTHLY_INCLUDED
  ANNUAL_INCLUDED
  WELCOME
  OVERAGE_PACK
}

enum CreditBucketStatus {
  PENDING
  ACTIVE
  EXHAUSTED
  EXPIRED
  CANCELED
}

enum CreditReservationStatus {
  PENDING
  ACTIVE
  PARTIALLY_CONSUMED
  CONSUMED
  RELEASED
  EXPIRED
  CANCELED
  FAILED
}

enum CreditLedgerType {
  GRANT
  RESERVE
  CONSUME
  RELEASE
  EXPIRE
  ADJUSTMENT
}

enum BillingLedgerEntryType {
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_CANCELED
  SUBSCRIPTION_EXPIRED
  OVERAGE_PURCHASED
  OVERAGE_REFUNDED
  ADJUSTMENT
}

enum BillingLedgerStatus {
  PENDING
  POSTED
  VOIDED
  FAILED
}

// ============================================================
// 1. Session
// ============================================================

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean?
  locale              String?
  collaborator        Boolean?
  emailVerified       Boolean?
  refreshToken        String?
  refreshTokenExpires DateTime?

  // ---------- Indexes ----------
  @@index([shop])
}

// ============================================================
// 2. Shop
// ============================================================

model Shop {
  id                      String    @id @default(cuid())
  shopDomain              String    @unique @map("shop_domain")
  accessTokenEncrypted    String    @map("access_token_encrypted")
  accessTokenNonce        String    @map("access_token_nonce")
  accessTokenTag          String    @map("access_token_tag")
  scopes                  String?
  currentPlan             String    @default("FREE") @map("current_plan")
  scanScopeFlags          Json      @default("{\"PRODUCT_MEDIA\":true,\"FILES\":true,\"COLLECTION_IMAGE\":true,\"ARTICLE_IMAGE\":true}") @map("scan_scope_flags")
  scanScopeUpdatedAt      DateTime? @map("scan_scope_updated_at")
  firstPaidBonusGrantedAt DateTime? @map("first_paid_bonus_granted_at")
  lastPublishedScopeFlags Json?     @map("last_published_scope_flags")
  lastPublishedScanJobId  String?   @map("last_published_scan_job_id")
  lastPublishedAt         DateTime? @map("last_published_at")
  installedAt             DateTime  @default(now()) @map("installed_at")
  uninstalledAt           DateTime? @map("uninstalled_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  // ---------- Relations ----------
  webhookEvents             WebhookEvent[]
  scanNoticeAcks            ScanNoticeAck[]
  shopOperationLock         ShopOperationLock?
  lastPublishedScanJob      ScanJob?                   @relation("ShopLastPublishedScanJob", fields: [lastPublishedScanJobId], references: [id], onDelete: SetNull)
  scanJobs                  ScanJob[]
  scanTasks                 ScanTask[]
  scanTaskAttempts          ScanTaskAttempt[]
  jobBatches                JobBatch[]
  billingSubscriptions      BillingSubscription[]
  overagePackPurchases      OveragePackPurchase[]
  creditBuckets             CreditBucket[]
  creditReservations        CreditReservation[]
  creditReservationLines    CreditReservationLine[]
  creditLedgers             CreditLedger[]
  billingLedgers            BillingLedger[]
  stgProducts               StgProduct[]
  stgMediaProducts          StgMediaImageProduct[]
  stgMediaFiles             StgMediaImageFile[]
  stgCollections            StgCollection[]
  stgArticles               StgArticle[]
  scanResultTargets         ScanResultTarget[]
  scanResultUsages          ScanResultUsage[]
  altTargets                AltTarget[]
  imageUsages               ImageUsage[]
  decorativeMarks           DecorativeMark[]
  altCandidates             AltCandidate[]
  candidateGroupProjections CandidateGroupProjection[]
  altDrafts                 AltDraft[]
  auditLogs                 AuditLog[]
  resourceImageFingerprints ResourceImageFingerprint[]

  // ---------- Indexes ----------
  @@index([currentPlan])
  @@index([lastPublishedScanJobId])
  @@index([uninstalledAt])
  @@index([uninstalledAt, currentPlan])
  @@map("shops")
}

// ============================================================
// 3. ScanNoticeAck
// ============================================================

model ScanNoticeAck {
  id                 String   @id @default(cuid())
  shopId             String   @map("shop_id")
  noticeVersion      String   @map("notice_version")
  scopeFlagsSnapshot Json     @map("scope_flags_snapshot")
  acknowledgedAt     DateTime @default(now()) @map("acknowledged_at")

  // ---------- Relations ----------
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, noticeVersion])
  @@index([noticeVersion])
  @@map("scan_notice_ack")
}

// ============================================================
// 4. ShopOperationLock
// ============================================================

model ShopOperationLock {
  shopId      String    @id @map("shop_id")
  lockType    String    @map("lock_type")
  batchId     String?   @map("batch_id")
  acquiredAt  DateTime  @default(now()) @map("acquired_at")
  heartbeatAt DateTime? @map("heartbeat_at")
  expiresAt   DateTime  @map("expires_at")
  releasedAt  DateTime? @map("released_at")
  status      String    @map("status")

  // ---------- Relations ----------
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@index([status, expiresAt])
  @@index([lockType, status])
  @@map("shop_operation_lock")
}

// ============================================================
// 5. WebhookEvent
// ============================================================

model WebhookEvent {
  id                   String             @id @default(cuid())
  shopDomain           String             @map("shop_domain")
  topic                String
  resourceId           String?            @map("resource_id")
  shopifyWebhookId     String             @unique @map("shopify_webhook_id")
  idempotencyKey       String             @unique @map("idempotency_key")
  apiVersion           String?            @map("api_version")
  payload              Json
  status               WebhookEventStatus @default(PENDING) @map("status")
  attempts             Int                @default(0)
  jobBatchId           String?            @map("job_batch_id")
  coalescedIntoEventId String?            @map("coalesced_into_event_id")
  queuedAt             DateTime?          @map("queued_at")
  lastAttemptAt        DateTime?          @map("last_attempt_at")
  processingStartedAt  DateTime?          @map("processing_started_at")
  processedAt          DateTime?          @map("processed_at")
  errorMessage         String?            @map("error_message")
  receivedAt           DateTime           @default(now()) @map("received_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop               Shop           @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  jobBatch           JobBatch?      @relation(fields: [jobBatchId], references: [id], onDelete: SetNull)
  coalescedIntoEvent WebhookEvent?  @relation("WebhookEventCoalescedInto", fields: [coalescedIntoEventId], references: [id], onDelete: SetNull)
  coalescedEvents    WebhookEvent[] @relation("WebhookEventCoalescedInto")

  // ---------- Indexes ----------
  @@index([status, receivedAt])
  @@index([shopDomain, topic, receivedAt])
  @@index([shopDomain, topic, resourceId, receivedAt])
  @@index([shopDomain, status, receivedAt])
  @@index([jobBatchId])
  @@index([coalescedIntoEventId])
  @@index([processedAt])
  @@index([lastAttemptAt])
  @@index([receivedAt])
  @@map("webhook_events")
}

// ============================================================
// 6. ScanJob
// ============================================================

model ScanJob {
  id                      String               @id @default(cuid())
  shopId                  String               @map("shop_id")
  status                  ScanJobStatus        @default(RUNNING)
  publishStatus           ScanJobPublishStatus @default(PENDING) @map("publish_status")
  scopeFlags              Json                 @map("scope_flags")
  noticeVersion           String               @map("notice_version")
  successfulResourceTypes Json                 @default("[]") @map("successful_resource_types")
  failedResourceTypes     Json                 @default("[]") @map("failed_resource_types")
  startedAt               DateTime             @default(now()) @map("started_at")
  finishedAt              DateTime?            @map("finished_at")
  publishedAt             DateTime?            @map("published_at")
  error                   String?

  // ---------- Relations ----------
  shop                 Shop                       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  publishedForShops    Shop[]                     @relation("ShopLastPublishedScanJob")
  scanTasks            ScanTask[]
  scanResultTargets    ScanResultTarget[]
  scanResultUsages     ScanResultUsage[]
  lastPublishedTargets AltTarget[]                @relation("LastPublishedScanJobAltTargets")
  lastPublishedUsages  ImageUsage[]               @relation("LastPublishedScanJobImageUsages")
  lastSeenUsages       ImageUsage[]               @relation("LastSeenScanJobImageUsages")
  lastSeenCandidates   AltCandidate[]              @relation("LastSeenScanJobAltCandidates")
  groupProjections     CandidateGroupProjection[]

  // ---------- Indexes ----------
  @@index([shopId])
  @@index([shopId, status, startedAt])
  @@index([publishStatus, startedAt])
  @@map("scan_job")
}

// ============================================================
// 7. ScanTask
// ============================================================

model ScanTask {
  id                  String           @id @default(cuid())
  shopId              String           @map("shop_id")
  scanJobId           String           @map("scan_job_id")
  resourceType        ScanResourceType @map("resource_type")
  status              ScanTaskStatus   @default(PENDING)
  currentAttemptNo    Int              @default(0) @map("current_attempt_no")
  successfulAttemptId String?          @unique @map("successful_attempt_id")
  maxParseAttempts    Int              @default(3) @map("max_parse_attempts")
  startedAt           DateTime         @default(now()) @map("started_at")
  finishedAt          DateTime?        @map("finished_at")
  error               String?

  // ---------- Relations ----------
  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanJob           ScanJob            @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  attempts          ScanTaskAttempt[]  @relation("ScanTaskAttempts")
  successfulAttempt ScanTaskAttempt?   @relation("SuccessfulScanTaskAttempt", fields: [successfulAttemptId], references: [id], onDelete: SetNull)
  scanResultTargets ScanResultTarget[]
  scanResultUsages  ScanResultUsage[]

  // ---------- Indexes ----------
  @@unique([scanJobId, resourceType])
  @@index([shopId])
  @@index([scanJobId, status])
  @@index([shopId, resourceType, status])
  @@map("scan_task")
}

// ============================================================
// 8. ScanTaskAttempt
// ============================================================

model ScanTaskAttempt {
  id                 String                @id @default(cuid())
  shopId             String                @map("shop_id")
  scanTaskId         String                @map("scan_task_id")
  attemptNo          Int                   @map("attempt_no")
  status             ScanTaskAttemptStatus @default(PENDING)
  bulkOperationId    String?               @unique @map("bulk_operation_id")
  bulkResultUrl      String?               @map("bulk_result_url")
  resultUrlFetchedAt DateTime?             @map("result_url_fetched_at")
  parsedRows         Int                   @default(0) @map("parsed_rows")
  lastParseError     String?               @map("last_parse_error")
  startedAt          DateTime              @default(now()) @map("started_at")
  finishedAt         DateTime?             @map("finished_at")

  // ---------- Relations ----------
  shop              Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanTask          ScanTask               @relation("ScanTaskAttempts", fields: [scanTaskId], references: [id], onDelete: Cascade)
  successfulForTask ScanTask?              @relation("SuccessfulScanTaskAttempt")
  stgProducts       StgProduct[]
  stgMediaProducts  StgMediaImageProduct[]
  stgMediaFiles     StgMediaImageFile[]
  stgCollections    StgCollection[]
  stgArticles       StgArticle[]

  // ---------- Indexes ----------
  @@unique([scanTaskId, attemptNo])
  @@index([shopId])
  @@index([scanTaskId, status])
  @@index([shopId, status, startedAt])
  @@map("scan_task_attempt")
}

// ============================================================
// 9. JobBatch
// ============================================================

model JobBatch {
  id            String         @id @default(cuid())
  shopId        String         @map("shop_id")
  type          JobBatchType
  reservationId String?        @unique @map("reservation_id")
  total         Int            @default(0)
  success       Int            @default(0)
  failed        Int            @default(0)
  skipped       Int            @default(0)
  status        JobBatchStatus @default(PENDING)
  startedAt     DateTime       @default(now()) @map("started_at")
  finishedAt    DateTime?      @map("finished_at")

  // ---------- Relations ----------
  shop          Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reservation   CreditReservation? @relation("JobBatchReservation", fields: [reservationId], references: [id], onDelete: SetNull)
  items         JobItem[]
  webhookEvents WebhookEvent[]
  auditLogs     AuditLog[]
  creditLedgers CreditLedger[]

  // ---------- Indexes ----------
  @@index([shopId])
  @@index([shopId, type, startedAt])
  @@index([shopId, status, startedAt])
  @@map("job_batch")
}

// ============================================================
// 10. JobItem
// ============================================================

model JobItem {
  id             String        @id @default(cuid())
  batchId        String        @map("batch_id")
  altCandidateId String        @map("alt_candidate_id")
  status         JobItemStatus @default(PENDING)
  error          String?

  // ---------- Relations ----------
  batch        JobBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  altCandidate AltCandidate @relation(fields: [altCandidateId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]

  // ---------- Indexes ----------
  @@unique([batchId, altCandidateId])
  @@index([altCandidateId])
  @@index([batchId, status])
  @@map("job_item")
}

// ============================================================
// 11. StgProduct
// ============================================================

model StgProduct {
  id                String @id @default(cuid())
  shopId            String @map("shop_id")
  scanTaskAttemptId String @map("scan_task_attempt_id")
  productId         String @map("product_id")
  title             String
  handle            String

  // ---------- Relations ----------
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanTaskAttempt ScanTaskAttempt @relation(fields: [scanTaskAttemptId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, scanTaskAttemptId, productId])
  @@index([shopId])
  @@index([scanTaskAttemptId])
  @@index([shopId, productId])
  @@index([scanTaskAttemptId, productId])
  @@map("stg_product")
}

// ============================================================
// 12. StgMediaImageProduct
// ============================================================

model StgMediaImageProduct {
  id                String  @id @default(cuid())
  shopId            String  @map("shop_id")
  scanTaskAttemptId String  @map("scan_task_attempt_id")
  mediaImageId      String  @map("media_image_id")
  parentProductId   String  @map("parent_product_id")
  alt               String?
  url               String
  width             Int?
  height            Int?
  positionIndex     Int?    @map("position_index")

  // ---------- Relations ----------
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanTaskAttempt ScanTaskAttempt @relation(fields: [scanTaskAttemptId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, scanTaskAttemptId, mediaImageId, parentProductId])
  @@index([shopId])
  @@index([scanTaskAttemptId])
  @@index([shopId, mediaImageId])
  @@index([shopId, parentProductId])
  @@index([scanTaskAttemptId, parentProductId, positionIndex])
  @@map("stg_media_image_product")
}

// ============================================================
// 13. StgMediaImageFile
// ============================================================

model StgMediaImageFile {
  id                String  @id @default(cuid())
  shopId            String  @map("shop_id")
  scanTaskAttemptId String  @map("scan_task_attempt_id")
  mediaImageId      String  @map("media_image_id")
  alt               String?
  url               String
  width             Int?
  height            Int?

  // ---------- Relations ----------
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanTaskAttempt ScanTaskAttempt @relation(fields: [scanTaskAttemptId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, scanTaskAttemptId, mediaImageId])
  @@index([shopId])
  @@index([scanTaskAttemptId])
  @@index([shopId, mediaImageId])
  @@map("stg_media_image_file")
}

// ============================================================
// 14. StgCollection
// ============================================================

model StgCollection {
  id                String  @id @default(cuid())
  shopId            String  @map("shop_id")
  scanTaskAttemptId String  @map("scan_task_attempt_id")
  collectionId      String  @map("collection_id")
  title             String
  handle            String
  imageAltText      String? @map("image_alt_text")
  imageUrl          String? @map("image_url")

  // ---------- Relations ----------
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanTaskAttempt ScanTaskAttempt @relation(fields: [scanTaskAttemptId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, scanTaskAttemptId, collectionId])
  @@index([shopId])
  @@index([scanTaskAttemptId])
  @@index([shopId, collectionId])
  @@map("stg_collection")
}

// ============================================================
// 15. StgArticle
// ============================================================

model StgArticle {
  id                String  @id @default(cuid())
  shopId            String  @map("shop_id")
  scanTaskAttemptId String  @map("scan_task_attempt_id")
  articleId         String  @map("article_id")
  title             String
  handle            String
  imageAltText      String? @map("image_alt_text")
  imageUrl          String? @map("image_url")

  // ---------- Relations ----------
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanTaskAttempt ScanTaskAttempt @relation(fields: [scanTaskAttemptId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, scanTaskAttemptId, articleId])
  @@index([shopId])
  @@index([scanTaskAttemptId])
  @@index([shopId, articleId])
  @@map("stg_article")
}

// ============================================================
// 16. ResourceImageFingerprint
// ============================================================

model ResourceImageFingerprint {
  id                     String                               @id @default(cuid())
  shopId                 String                               @map("shop_id")
  resourceType           ResourceImageFingerprintResourceType @map("resource_type")
  resourceId             String                               @map("resource_id")
  fingerprintHash        String                               @map("fingerprint_hash")
  lastProcessedWebhookId String?                              @map("last_processed_webhook_id")
  lastProcessedAt        DateTime?                            @map("last_processed_at")
  createdAt              DateTime                             @default(now()) @map("created_at")
  updatedAt              DateTime                             @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, resourceType, resourceId])
  @@index([shopId])
  @@index([shopId, resourceType])
  @@index([shopId, resourceType, fingerprintHash])
  @@index([lastProcessedWebhookId])
  @@map("resource_image_fingerprint")
}

// ============================================================
// 17. ScanResultTarget
// ============================================================

model ScanResultTarget {
  id              String           @id @default(cuid())
  shopId          String           @map("shop_id")
  scanJobId       String           @map("scan_job_id")
  resourceType    ScanResourceType @map("resource_type")
  altPlane        AltPlane         @map("alt_plane")
  writeTargetId   String           @map("write_target_id")
  locale          String           @default("default")
  displayTitle    String?          @map("display_title")
  displayHandle   String?          @map("display_handle")
  previewUrl      String?          @map("preview_url")
  currentAltText  String?          @map("current_alt_text")
  currentAltEmpty Boolean          @default(true) @map("current_alt_empty")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop     Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanJob  ScanJob           @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  scanTask ScanTask          @relation(fields: [scanJobId, resourceType], references: [scanJobId, resourceType], onDelete: Cascade)
  usages   ScanResultUsage[]

  // ---------- Indexes ----------
  @@unique([shopId, scanJobId, resourceType, altPlane, writeTargetId, locale])
  @@index([shopId])
  @@index([scanJobId])
  @@index([shopId, scanJobId, resourceType])
  @@index([shopId, altPlane, locale])
  @@map("scan_result_target")
}

// ============================================================
// 18. ScanResultUsage
// ============================================================

model ScanResultUsage {
  id            String           @id @default(cuid())
  shopId        String           @map("shop_id")
  scanJobId     String           @map("scan_job_id")
  resourceType  ScanResourceType @map("resource_type")
  altPlane      AltPlane         @map("alt_plane")
  writeTargetId String           @map("write_target_id")
  locale        String           @default("default")
  usageType     ImageUsageType   @map("usage_type")
  usageId       String           @map("usage_id")
  title         String?
  handle        String?
  positionIndex Int?             @map("position_index")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanJob          ScanJob          @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  scanTask         ScanTask         @relation(fields: [scanJobId, resourceType], references: [scanJobId, resourceType], onDelete: Cascade)
  scanResultTarget ScanResultTarget @relation(fields: [shopId, scanJobId, resourceType, altPlane, writeTargetId, locale], references: [shopId, scanJobId, resourceType, altPlane, writeTargetId, locale], onDelete: Cascade)

  // ---------- Indexes ----------
  @@unique([shopId, scanJobId, resourceType, altPlane, writeTargetId, usageType, usageId])
  @@index([shopId])
  @@index([scanJobId])
  @@index([shopId, usageType])
  @@index([shopId, scanJobId, resourceType])
  @@index([shopId, scanJobId, resourceType, altPlane, writeTargetId, locale])
  @@map("scan_result_usage")
}

// ============================================================
// 19. AltTarget
// ============================================================

model AltTarget {
  id                     String        @id @default(cuid())
  shopId                 String        @map("shop_id")
  altPlane               AltPlane      @map("alt_plane")
  writeTargetId          String        @map("write_target_id")
  locale                 String        @default("default")
  displayTitle           String?       @map("display_title")
  displayHandle          String?       @map("display_handle")
  previewUrl             String?       @map("preview_url")
  currentAltText         String?       @map("current_alt_text")
  currentAltEmpty        Boolean       @default(true) @map("current_alt_empty")
  lastPublishedScanJobId String        @map("last_published_scan_job_id")
  lastSeenAt             DateTime      @default(now()) @map("last_seen_at")
  presentStatus          PresentStatus @default(PRESENT) @map("present_status")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop                 Shop                       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  lastPublishedScanJob ScanJob                    @relation("LastPublishedScanJobAltTargets", fields: [lastPublishedScanJobId], references: [id], onDelete: Cascade)
  imageUsages          ImageUsage[]
  decorativeMark       DecorativeMark?
  altCandidate         AltCandidate?
  groupProjections     CandidateGroupProjection[]
  auditLogs            AuditLog[]

  // ---------- Indexes ----------
  @@unique([shopId, altPlane, writeTargetId, locale])
  @@index([shopId])
  @@index([lastPublishedScanJobId])
  @@index([shopId, altPlane, locale, presentStatus])
  @@map("alt_target")
}

// ============================================================
