  bucket        CreditBucket      @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  creditLedgers CreditLedger[]

  // ---------- Indexes ----------
  @@unique([reservationId, bucketId])
  @@index([shopId])
  @@index([reservationId])
  @@index([bucketId])
  @@index([shopId, bucketId])
  @@map("credit_reservation_line")
}

// ============================================================
// 31. CreditLedger
// ============================================================

model CreditLedger {
  id                       String           @id @default(cuid())
  shopId                   String           @map("shop_id")
  bucketId                 String           @map("bucket_id")
  reservationId            String?          @map("reservation_id")
  reservationLineId        String?          @map("reservation_line_id")
  jobBatchId               String?          @map("job_batch_id")
  type                     CreditLedgerType
  deltaAmount              Int              @map("delta_amount")
  balanceAfter             Int?             @map("balance_after")
  idempotencyKey           String           @unique @map("idempotency_key")
  externalBillingReference String?          @map("external_billing_reference")
  eventAt                  DateTime         @default(now()) @map("event_at")
  createdAt                DateTime         @default(now()) @map("created_at")

  // ---------- Relations ----------
  shop            Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  bucket          CreditBucket           @relation(fields: [bucketId], references: [id], onDelete: Cascade)
