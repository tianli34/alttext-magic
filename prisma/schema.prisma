  overagePackPurchase OveragePackPurchase?    @relation(fields: [overagePackPurchaseId], references: [id], onDelete: SetNull)
  reservationLines    CreditReservationLine[]
  creditLedgers       CreditLedger[]

  // ---------- Indexes ----------
  @@unique([shopId, bucketType, cycleKey])
  @@index([shopId])
  @@index([billingSubscriptionId])
  @@index([overagePackPurchaseId])
  @@index([shopId, status, expiresAt])
  @@index([shopId, bucketType, status, effectiveAt])
