// ============================================================
// AltText Magic — Phase 1 Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// 1. Session 表
// ============================================================

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean?
  locale              String?
  collaborator        Boolean?
  emailVerified       Boolean?
  refreshToken        String?
  refreshTokenExpires DateTime?

  // ---------- 索引 ----------
  @@index([shop])
}

// ============================================================
// 2. Shop 表
// ============================================================

model Shop {
  id                   String    @id @default(cuid())
  shopDomain           String    @unique @map("shop_domain")
  accessTokenEncrypted String    @map("access_token_encrypted")
  accessTokenNonce     String    @map("access_token_nonce")
  accessTokenTag       String    @map("access_token_tag")
  scopes               String?
  currentPlan          String    @default("FREE") @map("current_plan")
  scanScopeFlags       Int       @default(15) @map("scan_scope_flags")
  installedAt          DateTime  @default(now()) @map("installed_at")
  uninstalledAt        DateTime? @map("uninstalled_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // ---------- 关系 ----------
  webhookEvents WebhookEvent[]

  // ---------- 索引 ----------

  @@index([currentPlan])

  @@index([uninstalledAt])

  @@index([uninstalledAt, currentPlan])

  @@map("shops")
}

// ============================================================
// 3. WebhookEvent 表
// ============================================================

model WebhookEvent {
  id               String    @id @default(cuid())
  shopDomain       String    @map("shop_domain")
  topic            String
  shopifyWebhookId String    @unique @map("shopify_webhook_id")
  apiVersion       String?   @map("api_version")
  payload          Json
  status           String    @default("PENDING") @map("status")
  attempts         Int       @default(0)
  processedAt      DateTime? @map("processed_at")
  errorMessage     String?   @map("error_message")
  receivedAt       DateTime  @default(now()) @map("received_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // ---------- 关系 ----------
  shop Shop? @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  // ---------- 索引 ----------

  @@index([status, receivedAt])

  @@index([shopDomain, topic, receivedAt])

  @@index([receivedAt])

  @@map("webhook_events")
}