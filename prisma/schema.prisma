  lastSeenAt             DateTime       @default(now()) @map("last_seen_at")
  lastSeenScanJobId      String?        @map("last_seen_scan_job_id")
  presentStatus          PresentStatus  @default(PRESENT) @map("present_status")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop                 Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  altTarget            AltTarget @relation(fields: [altTargetId], references: [id], onDelete: Cascade)
  lastPublishedScanJob ScanJob   @relation("LastPublishedScanJobImageUsages", fields: [lastPublishedScanJobId], references: [id], onDelete: Cascade)
  lastSeenScanJob      ScanJob?  @relation("LastSeenScanJobImageUsages", fields: [lastSeenScanJobId], references: [id], onDelete: SetNull)

