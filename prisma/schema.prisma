// ============================================================
// 30. CreditReservationLine
// ============================================================

model CreditReservationLine {
  id             String   @id @default(cuid())
  shopId         String   @map("shop_id")
  reservationId  String   @map("reservation_id")
  bucketId       String   @map("bucket_id")
  reservedAmount Int      @map("reserved_amount")
  consumedAmount Int      @default(0) @map("consumed_amount")
  releasedAmount Int      @default(0) @map("released_amount")
