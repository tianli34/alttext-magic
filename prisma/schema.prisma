  reservationLine CreditReservationLine? @relation(fields: [reservationLineId], references: [id], onDelete: SetNull)
  jobBatch        JobBatch?              @relation(fields: [jobBatchId], references: [id], onDelete: SetNull)

  // ---------- Indexes ----------
  @@index([shopId])
  @@index([bucketId])
  @@index([reservationId])
  @@index([reservationLineId])
  @@index([jobBatchId])
  @@index([externalBillingReference])
  @@index([shopId, eventAt])
  @@index([shopId, type, eventAt])
  @@map("credit_ledger")
}

// ============================================================
