  status                CreditBucketStatus @default(PENDING)
  cycleKey              String?            @map("cycle_key")
  grantedAmount         Int                @map("granted_amount")
  reservedAmount        Int                @default(0) @map("reserved_amount")
  consumedAmount        Int                @default(0) @map("consumed_amount")
  effectiveAt           DateTime           @map("effective_at")
  expiresAt             DateTime?          @map("expires_at")
  activatedAt           DateTime?          @map("activated_at")
  exhaustedAt           DateTime?          @map("exhausted_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  // ---------- Relations ----------
  shop                Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
