  // ---------- Indexes ----------
  @@index([shopId])
  @@index([billingSubscriptionId])
  @@index([overagePackPurchaseId])
  @@index([externalBillingReference])
  @@index([shopId, status, occurredAt])
  @@index([shopId, entryType, occurredAt])
  @@map("billing_ledger")
}
