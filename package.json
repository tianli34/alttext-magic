{
  "name": "alttext-magic",
  "private": true,
  "scripts": {
    "dev": "shopify app dev",
    "dev:web": "react-router dev",
    "dev:worker": "tsx watch ./worker/index.ts",
    "dev:all": "npm-run-all2 --parallel dev:web dev:worker",
    "build": "react-router build",
    "build:worker": "tsc --project tsconfig.worker.json",
    "start": "react-router-serve ./build/server/index.js",
    "start:worker": "node ./dist-worker/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:schema:check": "tsx scripts/validate-database-schema.ts",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "railway:build": "npm run prisma:generate && npm run build && npm run build:worker",
    "railway:migrate": "npm run prisma:migrate:deploy",
    "typegen": "react-router typegen",
    "typecheck": "tsc --noEmit",
    "typecheck:full": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "shopify": "shopify",
    "generate:encryption-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "models": "tsx E:/typescript-prisma-query-tool/src/cli.ts models --list",
    "model": "tsx E:/typescript-prisma-query-tool/src/cli.ts model",
    "enum": "tsx E:/typescript-prisma-query-tool/src/cli.ts enum",
    "context": "tsx E:/typescript-prisma-query-tool/src/cli.ts context",
    "field": "tsx E:/typescript-prisma-query-tool/src/cli.ts field",
    "search": "tsx E:/typescript-prisma-query-tool/src/cli.ts search"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "bullmq": "^5.71.0",
    "ioredis": "^5.10.1",
    "isbot": "^5.1.31",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "uuid": "^13.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/config": "^7.5.0",
    "@react-router/dev": "^7.12.0",
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "latest",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "dotenv": "^17.3.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "graphql-config": "^5.1.1",
    "npm-run-all2": "^8.0.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "LiSama!"
}
